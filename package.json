{
  "name": "trpc-monorepo",
  "private": true,
  "scripts": {
    "build": "dotenv -- turbo build",
    "dev": "dotenv -- turbo dev",
    "devwatch": "node --watch node_modules/turbo/bin/turbo dev",
    "db:generate": "dotenv -- turbo db:generate",
    "db:migrate": "dotenv -- turbo db:migrate",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
     "dev:clean": "kill-port 8000 4983 5173 && turbo dev"
  },
  "devDependencies": {
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.7.4",
    "turbo": "^2.7.2",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "autoprefixer": "^10.5.0",
    "dotenv-cli": "^11.0.0"
  }
}
